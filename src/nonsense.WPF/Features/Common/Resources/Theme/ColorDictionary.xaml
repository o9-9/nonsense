<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!--
    Color Dictionary
    
    This file defines all color resources used throughout the application.
    Colors are organized into:
    1. Theme-specific colors (Dark/Light prefixes)
    2. Generic brushes that reference the appropriate theme color
    
    The naming convention uses generic terms (e.g., ControlForeground) rather than
    element-specific names (e.g., CheckBoxForeground) to promote reuse across
    different UI elements and maintain consistency.
    -->
    
    <!-- Dark Theme Colors -->
    <Color x:Key="DarkPrimaryTextColor">#EAEAEA</Color>
    <Color x:Key="DarkSecondaryTextColor">#CCCCCC</Color>
    <Color x:Key="DarkTertiaryTextColor">#808080</Color>
    <Color x:Key="DarkHelpIconColor">#EAEAEA</Color>
    <Color x:Key="DarkTooltipBackgroundColor">#3C3C41</Color>
    <Color x:Key="DarkTooltipForegroundColor">#EAEAEA</Color>
    <Color x:Key="DarkTooltipBorderColor">#38A2C5</Color>
    <Color x:Key="DarkControlForegroundColor">#EAEAEA</Color>
    <Color x:Key="DarkControlFillColor">#EAEAEA</Color>
    <Color x:Key="DarkControlBorderColor">#38A2C5</Color>
    <Color x:Key="DarkToggleKnobColor">#CECECE</Color>
    <Color x:Key="DarkToggleKnobCheckedColor">#000000</Color>
    <Color x:Key="DarkContentSectionBorderColor">#3C3C41</Color>
    <Color x:Key="DarkMainContainerBorderColor">#3C3C41</Color>
    <Color x:Key="DarkPrimaryButtonForegroundColor">#EAEAEA</Color>
    <Color x:Key="DarkAccentColor">#38A2C5</Color>
    <Color x:Key="DarkButtonHoverTextColor">#EAEAEA</Color>
    <Color x:Key="DarkButtonDisabledForegroundColor">#99A3A4</Color>
    <Color x:Key="DarkButtonDisabledBorderColor">#3C3C41</Color>
    <Color x:Key="DarkNavigationButtonBackgroundColor">#3C3C41</Color>
    <Color x:Key="DarkNavigationButtonForegroundColor">#EAEAEA</Color>
    <Color x:Key="DarkSliderTrackColor">#3C3C41</Color>
    <Color x:Key="DarkBackgroundColor">#3C3C41</Color>
    <Color x:Key="DarkContentSectionBackgroundColor">#3C3C41</Color>
    <Color x:Key="DarkElevatedBackgroundColor">#3C3C41</Color>
    <!-- Dark Theme ScrollBar Colors -->
    <Color x:Key="DarkScrollBarThumbColor">#A0A0A0</Color>
    <Color x:Key="DarkScrollBarThumbHoverColor">#B0B0B0</Color>
    <Color x:Key="DarkScrollBarThumbPressedColor">#C0C0C0</Color>

    <!-- Light Theme Colors -->
    <Color x:Key="LightPrimaryTextColor">#000000</Color>
    <Color x:Key="LightSecondaryTextColor">#555555</Color>
    <Color x:Key="LightTertiaryTextColor">#999999</Color>
    <Color x:Key="LightHelpIconColor">#000000</Color>
    <Color x:Key="LightTooltipBackgroundColor">#EAEAEA</Color>
    <Color x:Key="LightTooltipForegroundColor">#000000</Color>
    <Color x:Key="LightTooltipBorderColor">#38A2C5</Color>
    <Color x:Key="LightControlForegroundColor">#000000</Color>
    <Color x:Key="LightControlFillColor">#000000</Color>
    <Color x:Key="LightControlBorderColor">#38A2C5</Color>
    <Color x:Key="LightToggleKnobColor">#5D5D5D</Color>
    <Color x:Key="LightToggleKnobCheckedColor">#EAEAEA</Color>
    <Color x:Key="LightContentSectionBorderColor">#EAEAEA</Color>
    <Color x:Key="LightMainContainerBorderColor">#EAEAEA</Color>
    <Color x:Key="LightPrimaryButtonForegroundColor">#000000</Color>
    <Color x:Key="LightAccentColor">#38A2C5</Color>
    <Color x:Key="LightButtonHoverTextColor">#000000</Color>
    <Color x:Key="LightButtonDisabledForegroundColor">#CCCCCC</Color>
    <Color x:Key="LightButtonDisabledBorderColor">#EEEEEE</Color>
    <Color x:Key="LightNavigationButtonBackgroundColor">#EAEAEA</Color>
    <Color x:Key="LightNavigationButtonForegroundColor">#000000</Color>
    <Color x:Key="LightSliderTrackColor">#F5F5F5</Color>
    <Color x:Key="LightBackgroundColor">#EAEAEA</Color>
    <Color x:Key="LightContentSectionBackgroundColor">#EAEAEA</Color>
    <Color x:Key="LightElevatedBackgroundColor">#EAEAEA</Color>
    <!-- Light Theme ScrollBar Colors -->
    <Color x:Key="LightScrollBarThumbColor">#A0A0A0</Color>
    <Color x:Key="LightScrollBarThumbHoverColor">#B0B0B0</Color>
    <Color x:Key="LightScrollBarThumbPressedColor">#808080</Color>

    <!-- Dynamic Theme Brushes -->
    <!-- Text Colors -->
    <SolidColorBrush x:Key="PrimaryTextColor"
            Color="{DynamicResource DarkPrimaryTextColor}"/>
    <SolidColorBrush x:Key="SecondaryTextColor"
            Color="{DynamicResource DarkSecondaryTextColor}"/>
    <SolidColorBrush x:Key="TertiaryTextColor"
            Color="{DynamicResource DarkTertiaryTextColor}"/>
    <SolidColorBrush x:Key="SubTextColor"
            Color="{DynamicResource DarkSecondaryTextColor}"/>

    <!-- UI Element Colors -->
    <SolidColorBrush x:Key="HelpIconForeground"
            Color="{DynamicResource DarkHelpIconColor}"/>
    <SolidColorBrush x:Key="WindowBackground"
            Color="{DynamicResource DarkBackgroundColor}"/>
    <SolidColorBrush x:Key="ContentSectionBorderBrush"
            Color="{DynamicResource DarkContentSectionBorderColor}"/>
    <SolidColorBrush x:Key="MainContainerBorderBrush"
            Color="{DynamicResource DarkMainContainerBorderColor}"/>

    <!-- Button Colors -->
    <SolidColorBrush x:Key="PrimaryButtonForeground"
            Color="{DynamicResource DarkPrimaryButtonForegroundColor}"/>
    <SolidColorBrush x:Key="ButtonBorderBrush"
            Color="{DynamicResource DarkAccentColor}"/>
    <SolidColorBrush x:Key="ButtonHoverBackground"
            Color="{DynamicResource DarkAccentColor}"/>
    <SolidColorBrush x:Key="ButtonHoverTextColor"
            Color="{DynamicResource DarkButtonHoverTextColor}"/>
    <SolidColorBrush x:Key="ButtonDisabledForeground"
            Color="{DynamicResource DarkButtonDisabledForegroundColor}"/>
    <SolidColorBrush x:Key="ButtonDisabledBorderBrush"
            Color="{DynamicResource DarkButtonDisabledBorderColor}"/>
    <SolidColorBrush x:Key="ButtonDisabledHoverBackground"
            Color="{DynamicResource DarkButtonDisabledBorderColor}"/>
    <SolidColorBrush x:Key="ButtonDisabledHoverForeground"
            Color="{DynamicResource DarkButtonDisabledForegroundColor}"/>

    <!-- Navigation Colors -->
    <SolidColorBrush x:Key="NavigationButtonBackground"
            Color="{DynamicResource DarkNavigationButtonBackgroundColor}"/>
    <SolidColorBrush x:Key="NavigationButtonForeground"
            Color="{DynamicResource DarkNavigationButtonForegroundColor}"/>

    <!-- Tooltip Colors -->
    <SolidColorBrush x:Key="TooltipBackground"
            Color="{DynamicResource DarkTooltipBackgroundColor}"/>
    <SolidColorBrush x:Key="TooltipForeground"
            Color="{DynamicResource DarkTooltipForegroundColor}"/>
    <SolidColorBrush x:Key="TooltipBorderBrush"
            Color="{DynamicResource DarkTooltipBorderColor}"/>

    <!-- Control Colors (Checkbox, Toggle Switch, etc.) -->
    <SolidColorBrush x:Key="ControlForeground"
            Color="{DynamicResource DarkControlForegroundColor}"/>
    <SolidColorBrush x:Key="ControlFillColor"
            Color="{DynamicResource DarkControlFillColor}"/>
    <SolidColorBrush x:Key="ControlBorderBrush"
            Color="{DynamicResource DarkControlBorderColor}"/>
    
    <!-- Toggle Switch Specific Colors -->
    <SolidColorBrush x:Key="ToggleKnobBrush"
            Color="{DynamicResource DarkToggleKnobColor}"/>
    <SolidColorBrush x:Key="ToggleKnobCheckedBrush"
            Color="{DynamicResource DarkToggleKnobCheckedColor}"/>

    <!-- Slider Colors -->
    <SolidColorBrush x:Key="SliderTrackBackground"
            Color="{DynamicResource DarkSliderTrackColor}"/>
    <SolidColorBrush x:Key="SliderAccentColor"
            Color="{DynamicResource DarkAccentColor}"/>
    <SolidColorBrush x:Key="TickBarForeground"
            Color="{DynamicResource DarkPrimaryTextColor}"/>

    <!-- ScrollBar Brushes -->
    <SolidColorBrush x:Key="ScrollBarThumbBrush"
            Color="{DynamicResource DarkScrollBarThumbColor}"/>
    <SolidColorBrush x:Key="ScrollBarThumbHoverBrush"
            Color="{DynamicResource DarkScrollBarThumbHoverColor}"/>
    <SolidColorBrush x:Key="ScrollBarThumbPressedBrush"
            Color="{DynamicResource DarkScrollBarThumbPressedColor}"/>

    <!-- Window Content Sections -->
    <SolidColorBrush x:Key="ContentSectionBackground"
            Color="{DynamicResource DarkContentSectionBackgroundColor}"/>
    <SolidColorBrush x:Key="ElevatedBackground"
            Color="{DynamicResource DarkElevatedBackgroundColor}"/>

    <!-- Effects -->
    <DropShadowEffect x:Key="ShadowEffect"
                      ShadowDepth="5"
                      BlurRadius="10"
                      Color="Black"/>

    <DropShadowEffect x:Key="LightShadowEffect"
                      ShadowDepth="5"
                      BlurRadius="10"
                      Color="Black"
                      Opacity="0.5"/>

    <DropShadowEffect x:Key="UltraLightShadowEffect"
                      ShadowDepth="2"
                      BlurRadius="5"
                      Color="Black"
                      Opacity="0.5"
                      Direction="270"/>
</ResourceDictionary>