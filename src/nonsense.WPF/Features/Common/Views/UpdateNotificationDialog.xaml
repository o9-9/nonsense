<Window x:Class="nonsense.WPF.Features.Common.Views.UpdateNotificationDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        xmlns:converters="clr-namespace:nonsense.WPF.Features.Common.Converters"
        x:Name="DialogWindow"
        Title="Update Available" 
        Width="550"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="True"
        Topmost="True">
    
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <converters:InverseBooleanConverter x:Key="InverseBooleanConverter"/>
    </Window.Resources>
    
    <Grid>
        <Grid.OpacityMask>
            <VisualBrush>
                <VisualBrush.Visual>
                    <Border Background="Black"
                            CornerRadius="10"
                            Width="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=Grid}}"
                            Height="{Binding ActualHeight, RelativeSource={RelativeSource AncestorType=Grid}}"/>
                </VisualBrush.Visual>
            </VisualBrush>
        </Grid.OpacityMask>

        <Border CornerRadius="10"
                BorderBrush="Transparent"
                Background="{DynamicResource WindowBackground}">
            <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <!-- Header -->
            <Grid Grid.Row="0" Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <iconPacks:PackIconMaterial Kind="Update" Width="32" Height="32" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBlock Text="Update Available" FontSize="22" VerticalAlignment="Center" FontWeight="Medium"/>
                </StackPanel>
                
                <Button x:Name="CloseButton"
                        Grid.Column="1"
                        Style="{StaticResource IconButtonStyle}"
                        Click="CloseButton_Click"
                        HorizontalAlignment="Right">
                    <iconPacks:PackIconMaterial Kind="Close" Width="12" Height="12"/>
                </Button>
            </Grid>
            
            <!-- Version Info -->
            <StackPanel Grid.Row="1" Margin="0,0,0,15">
                <TextBlock x:Name="UpdateMessageText" Text="A new version of nonsense is available." TextWrapping="Wrap" Margin="0,0,0,15"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Current Version:" FontWeight="SemiBold" Margin="0,0,10,5"/>
                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding CurrentVersion}" Margin="0,0,0,5"/>
                    
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Latest Version:" FontWeight="SemiBold" Margin="0,0,10,0"/>
                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding LatestVersion}" Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                </Grid>
            </StackPanel>
            
            <!-- Status -->
            <TextBlock x:Name="StatusText" Grid.Row="2" Text="{Binding StatusMessage}" TextWrapping="Wrap" Margin="0,0,0,15"/>
            
            <!-- Progress -->
            <ProgressBar Grid.Row="3" IsIndeterminate="{Binding IsDownloading}">
                <ProgressBar.Visibility>
                    <Binding Path="IsDownloading">
                        <Binding.Converter>
                            <BooleanToVisibilityConverter/>
                        </Binding.Converter>
                    </Binding>
                </ProgressBar.Visibility>
                <ProgressBar.Margin>0,10,0,15</ProgressBar.Margin>
            </ProgressBar>
            
            <!-- Buttons -->
            <Grid Grid.Row="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <Button x:Name="PrimaryButton"
                        Grid.Column="2"
                        Content="Download and Install"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Click="PrimaryButton_Click"
                        Margin="8,0,0,0">
                    <Button.IsEnabled>
                        <Binding Path="IsDownloading">
                            <Binding.Converter>
                                <converters:InverseBooleanConverter/>
                            </Binding.Converter>
                        </Binding>
                    </Button.IsEnabled>
                </Button>

                <Button x:Name="SecondaryButton"
                        Grid.Column="1"
                        Content="Remind Later"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Click="SecondaryButton_Click">
                    <Button.IsEnabled>
                        <Binding Path="IsDownloading">
                            <Binding.Converter>
                                <converters:InverseBooleanConverter/>
                            </Binding.Converter>
                        </Binding>
                    </Button.IsEnabled>
                </Button>
            </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
